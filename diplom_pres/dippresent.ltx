	\begin{frame}
		\begin{itemize}
			\frametitle{Теория осцилляций нейтрино (случай распространения в веществе)}
			\item<1->Оценим долю каждого вклада в упругое рассеяние первого порядка 
			относительно вклада взаимодействия с электроном по средством нейтрального тока 
			по следующему подходу:
			\begin{itemize}
				\item<2->Вычисляем интенсивность как произведение вершин соответствующей 
				диаграммы по модулю;
				\item<3->Делим интенсивность каждого вклада на интенсивность клада 
				взаимодействия с электроном по средством нейтрального тока;
			\end{itemize}
			\item<4-> Используем следующие выражения для вершин диаграмм:
			\begin{itemize}
				\item<4-> Для \(W^{\pm}\)-бозонной вершины с лептонами имеем
				\begin{equation}
					\frac{g}{2\sqrt{2}}\gamma^{\alpha}(1-\gamma^{5});
				\end{equation}
				\item<5-> Для \(Z^{0}\)-бозонной вершины с нейтрино
				\begin{equation}
					\frac{g}{4\cos\theta_{W}}\gamma^{\alpha}(1-\gamma^{5}).
				\end{equation}
				\item<6-> Для \(Z^{0}\)-бозонной вершины с заряженным лептоном
				\begin{equation}
					\frac{g}{2\cos\theta_{W}}\gamma^{\alpha}\left( 
					\frac{1}{2}(1-\gamma^{5})+2\sin^{2}\theta_{W}\right) ,
				\end{equation}
				где \(g_{v}\) и \(g_{a}\) это коэффициенты векторной и аксиальной аномалии. Их для 
				простоты 
				возьмём равными 1. 
			\end{itemize}
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Теория осцилляций нейтрино (случай распространения в веществе)}
		\begin{itemize}
			\item<1->Для \(W^{+}\) и \(W^{-}\)-бозонных вершин с кварками (\(u_{i}-W^{+}-d_{k}\)) и 
			(\(d_{i}-W^{-}-u_{k}\)) имеем соответственно 
			\begin{align}
				\frac{g}{2\sqrt{2}}V_{Ii}\gamma^{\alpha}(1-\gamma^{5}), \\ 
				\frac{g}{2\sqrt{2}}V_{iI}^{\dagger}\gamma^{\alpha}(1-\gamma^{5}).
			\end{align}
			\item<2->Для \(Z^{0}\)-бозонной вершины с кварками (\(u_{i}-Z^{0}-u_{i}\)) и 
			(\(d_{i}-Z^{0}-d_{i}\)) 
			имеем 
			соответственно
			\begin{align}
				\frac{g}{2\cos\theta_{W}}\gamma^{\alpha}\left( 
				\frac{1}{2}(1-\gamma^{5})-\frac{4}{3}\sin^{2}\theta_{W}\right) ,\\
				\frac{g}{2\cos\theta_{W}}\gamma^{\alpha}\left( 
				-\frac{1}{2}(1-\gamma^{5})+\frac{2}{3}\sin^{2}\theta_{W}\right)
			\end{align}
		\end{itemize}
	\end{frame}

	\begin{frame}
		\frametitle{Теория осцилляций нейтрино (случай распространения в веществе)}
