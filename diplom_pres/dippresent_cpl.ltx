	\begin{frame}
		\frametitle{Постановка задачи}
		\begin{itemize}
			\item<1-> Цель работы: оценка влияния вариации углов смешивания и параметров 
			среды на вероятности перехода нейтрино; 
			\item<2-> Задачи работы:
			\begin{itemize}
				\item<3-> Разобрать феноменологическую теорию нейтринных осцилляций;
				\item<4-> Провести численные расчёты вероятностей переходов при вариации 
				параметров профиля плотности среды и углов смешивания;
				\item<5-> Проанализировать полученные данные и сделать вывод о степени 
				влияния вариации на значения вероятностей;
			\end{itemize}
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Введение}
		\begin{itemize}
			\item<1-> Нейтрино — это нейтральные частицы относящиеся классу лептонов;
			\item<2-> В феноменологии выделяют два типа нейтрино: массивное и флейворное.
			\item<3-> Три типа флейворных (\(\nu_{e}\), \(\nu_{\mu}\), \(\nu_{\tau}\))  и три типа 
				массивных (\(\nu_{1}\), \(\nu_{2}\), \(\nu_{3}\)) состояний;
				\item<4-> Самая необычная черта нейтрино — это их осцилляции —
				периодические переходы между флейворами этих частиц;
				\item<5-> Осцилляции нейтрино в веществе значительно отличается от осцилляций 
				в вакууме и зависят от плотности среды;
				\item<6-> Эффект осцилляций в веществе можно использовать для исследования 
				внутреннего строения какого-либо объекта;
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Осцилляции в вакууме}
		\begin{itemize}
			\item<1->Для нейтрино в массивном представлении справедливо уравнение 
			Шредингера
			\begin{equation}
				\label{eq:1}
				\imath\frac{\dd}{\dd t}\ket{\nu_{i}(t)} = H\ket{\nu_{i}(t)}=
				E_{i}\ket{\nu_{i}(t)},\quad E_{i}=\sqrt{|\Vect{p}|^{2}+m_{i}^{2}}.
			\end{equation}
			\item<2-> Подействуем на решение уравнения \eqref{eq:1} в случае фиксированной 
			энергии оператором трансляции и, учитывая ультрарелятивистское приближение, 
			перепишем импульс так
			\begin{equation}
				p_{i}=\sqrt{E^{2}-m_{i}^{2}}\approx E-\frac{m_{i}^{2}}{2E}.
			\end{equation}
			\item<4-> Тогда итоговое выражение для эволюции без учёта общей фазы будет
			иметь вид
			\begin{equation}
				\label{eq:2}
				\ket{\nu_{i}(L)} = \exp^{-\imath \frac{m_{i}^{2}}{2E}L}\ket{\nu_{i}(0)}.
			\end{equation}
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Осцилляции в вакууме}
		\begin{itemize}
			\item<1-> Это соотношение можно рассматривать как решение уравнения следующего 
			типа
			\begin{equation}
				\label{eq:3}
				\imath \frac{\dd}{\dd\xi} \ket{\nu(\xi)}=
				H_{\text{eff}}\ket{\nu(\xi)},\quad
				\ket{\nu(\xi)}=
				\begin{pmatrix}
					\ket{\nu_{1}(\xi)}\\
					\ket{\nu_{2}(\xi)}\\
					\ket{\nu_{3}(\xi)}
				\end{pmatrix},\quad
				H_{\text{eff}}=\frac{M^{2}}{2E}.
			\end{equation}
			\item<2-> Перепишем выражение \eqref{eq:2} в флейворном представлении, используя 
			соотношение 
			\begin{equation}
				\label{eq:4}
				\ket{\nu_{\alpha}} = \sum_{i}U^{*}_{\alpha i}\ket{\nu_{i}},
			\end{equation}
			где \(U\) --- это PMNS-матрица, с учётом \(\delta_{CP}=0\) она записывается так
			\begin{equation}
				U=
				\begin{pmatrix}
					c_{12}c_{13}&s_{12}c_{13}&s_{13}\\
					-s_{12}c_{23}-c_{12}s_{23}s_{13}&c_{12}c_{23}-s_{12}s_{23}s_{13}&s_{23}c_{13}\\
					s_{12}s_{23}-c_{12}c_{23}s_{13}&-c_{12}s_{23}-s_{12}c_{23}s_{13}&c_{23}c_{13}
				\end{pmatrix},
			\end{equation}
			где обозначения \(c_{ij}\) и \(s_{ij}\) это соответственно \(\cos\theta_{ij}\) и 
			\(\sin\theta_{ij}\).
			\item<3-> Используя полученные соотношения, можно вычислить вероятность 
			перехода, используя следующее определение
			\begin{equation}
				P(\nu_{\alpha}\rightarrow\nu_{\beta})=|\langle\nu_{\beta}\ket{\nu_{\alpha}(L)}|^{2}.
			\end{equation} 
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Осцилляции в веществе}
		\begin{itemize}
			\item<1-> На осцилляцию нейтрино в веществе влияет МСВ-эффект --- эффект 
			возникающий при когерентном упругом рассеянии вперёд нейтрино на частицах 
			вещества (нуклоны, электроны).
			\item<2-> Оценки вкладов от упругого рассеяния нейтрино на частицах среды в 
			первом порядке относительно вклада от взаимодействия с электроном через 
			нейтральный ток
			\begin{align*}
				I(e-Z^{0})=1,\\
				I(e-W^{\pm})\approx 0,77,\\
				I(d_{i}-Z^{0})\approx 0,31,\\
				I(u_{i}-Z^{0})\approx 0,16,\\
			\end{align*}
			\item<3-> МСВ-эффект можно учесть, введя добавку в эффективный гамильтониан 
			распространения в пространстве. 
			\item<4-> Сама добавка получена с использованием эффективной теории Ферми, 
			поэтому имеется ограничение на энергии рассматриваемых нейтрино \(E\ll M_{W}\).
		\end{itemize}
	\end{frame}
	
	\begin{frame}
		\frametitle{Осцилляции в веществе}
		\begin{itemize}
			\item<1-> В итоговое уравнение на амплитуды перехода массивных состояний имеет 
			следующий вид
			\begin{equation}
				\label{eq:5}
				\imath\frac{\dd\Psi(r)}{\dd r}=H(r)\Psi(r),
				\qquad
				H(r)=H_{0}+v(r)W, 
			\end{equation} 
			где \(H_{0}=\diag(0,\frac{\Delta m^{2}_{21}}{2E},\frac{\Delta m^{2}_{31}}{2E})\), 
			\(W=U^{\dagger}\diag(1,0,0)U\), \(\nu(r)\) --- функция профиля плотности.
			\item<2-> Средняя вероятность перехода будет вычисляться по следующей формуле
			\begin{equation}
				\label{eq:6}
				\langle P_{\alpha\beta}\rangle=\langle P(\nu_{\alpha}\rightarrow\nu_{\beta}) 
				\rangle=\sum_{i}|U_{\beta i}|^{2}\rho_{i}, \quad \rho_{i}=|A_{i}|^{2}.
			\end{equation}
			\item<3-> Для случая перехода в электронное состояние формула вероятности будет 
			выглядеть так
			\begin{equation}
				\langle 
				P(\nu_{\alpha}\rightarrow\nu_{e})\rangle=c_{12}^2c_{13}^{2}\rho_{1}+s_{12}^{2}c_{13}^{2}\rho_{2}+s_{13}^{2}\rho_{3},
				\quad \rho_{i}=\abs{A_{i}}^{2};
			\end{equation}
		\end{itemize}
	\end{frame}
	
