			\begin{equation}
				\label{eq:1110}
				\eta=\frac{\Prob_{f}-\Prob_{0}}{\Prob_{0}}.
			\end{equation}
			\item<4-> Вариация углов
			\begin{equation}
				\label{eq:1111}
				\sin{\theta_{f}}=f\cdot \sin{\theta_{0}},\quad f\in \left[ 0,9;1,1\right] 
