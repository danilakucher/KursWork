	\begin{frame}
		\frametitle{Постановка задачи}
			\textbf{Цель работы}: оценка влияния вариации углов смешивания и параметров 
			среды на вероятности перехода нейтрино; 
			\\[2ex]
			\textbf{Задачи работы}:
			
				-Провести численные расчёты вероятностей переходов при вариации 
				параметров профиля плотности среды и углов смешивания;
			\\[2ex]
				-Проанализировать полученные данные и сделать вывод о степени 
				влияния вариации на значения вероятностей;
	\end{frame}	
	
	\begin{frame}
		\frametitle{Введение}
		\begin{itemize}
			\item<1-> Нейтрино — это нейтральные частицы относящиеся классу лептонов;
			\item<2-> В феноменологии у нейтрино существует два представления: массивное и 
			флейворное.
			\item<3-> Три флейворных состояния: \(\nu_{e}\), \(\nu_{\mu}\), 
			\(\nu_{\tau}\);
			\item<4-> Три массивных состояния: \(\nu_{1}\), \(\nu_{2}\), 
			\(\nu_{3}\);
			\item<5-> Самая необычная черта нейтрино --- это их осцилляции;
			\item<6-> Осцилляции нейтрино зависят от плотности среды, в которой 
			распространяются;
			\item<7-> Осцилляции нейтрино в веществе можно использовать для исследования 
				внутреннего строения какого-либо объекта;
		\end{itemize}
	\end{frame}
	
