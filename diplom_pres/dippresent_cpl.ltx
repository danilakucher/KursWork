	\begin{frame}
				\frametitle{Теоретическое описание}
				\begin{itemize}
						\item<1-> Уравнение на амплитуды перехода массивных состояний
						\begin{equation}
								\label{eq:115}
								\imath\frac{\dd\Psi(r)}{\dd r}=H(r)\Psi(r),
								\qquad
								H(r)=H_{0}+v(r)W, 
							\end{equation} 
						где \(v(r)\) --- функция профиля плотности,
						\item<2->\begin{equation*}
							H_{0}=\frac{a}{E}
							\begin{pmatrix}
								0&0&0\\
								0&b&0\\
								0&0&1\\
							\end{pmatrix}, \quad a=4,35196\cdot10^{6}, \quad b=0,030554,
						\end{equation*}
						\item<3->\begin{equation*}
							W=
							\begin{pmatrix}
								c_{13}^{2}c_{12}^{2}&c_{12}s_{12}c_{13}^{2}&c_{12}c_{13}s_{13}\\
								c_{12}s_{12}c_{13}^{2}&s_{12}^{2}c_{13}^{2}&s_{12}c_{13}s_{13}\\
								c_{12}s_{13}c_{13}&s_{12}c_{13}s_{13}&s_{13}^{2}
							\end{pmatrix},
						\end{equation*}
						\(c_{ij}\) и \(s_{ij}\) это соответственно \(\cos\theta_{ij}\) и 
						\(\sin\theta_{ij}\), в свою очередь \(\theta_{ij}\) --- это углы смешивания.
						\item<4-> Средняя вероятность перехода
						\begin{equation}
								\label{eq:116}
								\langle P_{\alpha\beta}\rangle=\langle P(\nu_{\alpha}\rightarrow\nu_{\beta}) 
								\rangle=\sum_{i}|U_{\beta i}|^{2}\rho_{i}, \quad \rho_{i}=|\Psi_{i}|^{2}.
							\end{equation}
				\end{itemize}
	\end{frame}
	
