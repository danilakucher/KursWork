\PYG{l+s+sd}{  Plot z (relative difference) as function of log(x) and y with color filled}
\PYG{l+s+sd}{  regions and contours.}
\PYG{l+s+sd}{  \PYGZdq{}\PYGZdq{}\PYGZdq{}}

  \PYG{n}{mx} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{max}\PYG{p}{(}\PYG{n}{z}\PYG{p}{)}
