  i2 [particle=\(l_{\alpha}^{+}\)]
    -- [anti fermion] b
    -- [anti fermion] f2 [particle=\(\nu_{\alpha}\)]%
};

\newpage

\feynmandiagram[layered layout, horizontal=a to b]{%
% Draw the top and bottom lines
  i1 [particle=\(u_{i}\)]
    -- [fermion] a
    -- [fermion, edge label=\(d_{k}\)] b
    -- [fermion] f1 [particle=\(u_{i}\)],%
  i2 [particle=\(\nu_{\alpha}\)]
    -- [fermion] c
    -- [fermion, edge label'=\(l^{+}_{\alpha}\)] d
    -- [fermion] f2 [particle=\(\nu_{\alpha}\)],%
  % Draw the two internal fermion lines
  { [same layer] a -- [charged boson, edge label'=\(\particle{W}^{+}\)] c },%
  { [same layer] b -- [anti charged boson, edge label=\(\particle{W}^{+}\)] d},
};

\newpage

\feynmandiagram[layered layout, horizontal=a to b]{%
% Draw the top and bottom lines
